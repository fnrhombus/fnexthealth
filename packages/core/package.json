{
  "name": "fnexthealth",
  "displayName": "Extension Health Monitor",
  "description": "Audit your installed VS Code extensions for security risks, staleness, and health.",
  "version": "0.1.0",
  "publisher": "fnrhombus",
  "license": "MIT",
  "author": "fnrhombus",
  "repository": {
    "type": "git",
    "url": "https://github.com/fnrhombus/fnexthealth"
  },
  "bugs": {
    "url": "https://github.com/fnrhombus/fnexthealth/issues"
  },
  "homepage": "https://github.com/fnrhombus/fnexthealth#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
